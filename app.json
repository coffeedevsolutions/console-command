{
  "expo": {
    "name": "console-command",
    "slug": "console-command",
    "owner": "whir",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/control-panel-icon.png",
    "userInterfaceStyle": "light",
    "runtimeVersion": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/a512f2cb-f81d-4c59-a045-07f772527d51",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.whir.consolecommand",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Console Command connects to your Whir console over the local network to send control commands.",
        "NSAppleMusicUsageDescription": "Console Command shows what's playing and lets you control Apple Music playback that's streaming to the console.",
        "NSBonjourServices": [
          "_http._tcp",
          "_http._tcp"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "3"
    },
    "android": {
      "package": "com.whir.consolecommand",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-audio",
      "expo-secure-store",
      "expo-updates",
      [
        "react-native-audio-api",
        {
          "iosMicrophonePermission": "Console Command uses the microphone to create live audio-reactive visuals from what's playing."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "a512f2cb-f81d-4c59-a045-07f772527d51"
      }
    }
  }
}
